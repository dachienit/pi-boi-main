\n  color: #111827;\n}\n.actions {\n  margin-top: 16px;\n  display: flex;\n  gap: 12px;\n}\n.btn {\n  appearance: none;\n  border: none;\n  border-radius: 999px;\n  padding: 10px 16px;\n  font-size: 14px;\n  cursor: pointer;\n  background: #111827;\n  color: #fff;\n  transition: transform .2s ease;\n}\n.btn:hover { transform: translateY(-1px); }\n.btn.secondary {\n  background: #f3f4f6;\n  color: #111827;\n}\n@media (max-width: 420px) {\n  .card { padding: 20px; }\n  .card h1 { font-size: 22px; }\n}\n</style>\n</head>\n<body>\n  <div class='app'>\n    <section class='card' aria-label='HTML sample card'>\n      <div class='header'>\n        <span class='badge' aria-hidden='true'></span>\n        <div class='title'>HTML Sample – Enhanced</div>\n      </div>\n      <h1>Hello from Enhanced HTML</h1>\n      <p>This version adds a smooth gradient background, a glassy card, subtle shadows, and responsive layout. No external dependencies.</p>\n      <div class='actions'>\n        <button class='btn' onclick='alert(\"Hello!\")'>Say Hi</button>\n        <button class='btn secondary' onclick='location.reload()'>Refresh</button>\n      </div>\n    </section>\n  </div>\n</body>\n</html>"}}],"api":"openai-completions","provider":"openai","model":"gpt-5-nano-2025-08-07","usage":{"input":3821,"output":4569,"cacheRead":0,"cacheWrite":0,"totalTokens":8390,"cost":{"input":0.0022543899999999998,"output":0.0036095100000000002,"cacheRead":0,"cacheWrite":0,"total":0.0058639}},"stopReason":"toolUse","timestamp":1776227767308}}
